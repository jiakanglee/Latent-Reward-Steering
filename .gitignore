.env
wandb
__pycache__
.DS_Store
base_models_reasoning_interp.egg-info/

# 运行时拉取的大模型缓存（勿提交）
.cache/
**/hf_cache/

# ---------------------------------------------------------------------------
# log2：本地实验产物与输出，不入库
# ---------------------------------------------------------------------------
log2/

logs/

# 仓库根目录 *.slurm 默认不入库。以下 GPQA / IneqMath 作业脚本纳入版本管理（子目录 steering/、PST/ 等不受影响）。
/*.slurm
!run_gpqa_diamond_aime_rm.slurm
!run_gpqa_diamond_aime_rm_mcq_collect_ilab2.slurm
!run_gpqa_diamond_baseline_official.slurm
!run_dump_gpqa_decode_sample.slurm
!run_ineqmath_aime_rm.slurm
!run_ineqmath_steer_sweep.slurm

# ---------------------------------------------------------------------------
# 为何 .git 曾有 ~3.7GiB：主要是「历史里提交过的」下面这些目录，不是 log2。
